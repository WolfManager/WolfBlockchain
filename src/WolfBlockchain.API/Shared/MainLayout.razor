@inherits LayoutComponentBase
@inject ClientAuthService AuthService
@inject NavigationManager Navigation

<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="/">🐺 Wolf Blockchain</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto">
                <li class="nav-item">
                    <a class="nav-link" href="/">Home</a>
                </li>
                @if (isAuthenticated)
                {
                    <li class="nav-item">
                        <a class="nav-link" href="/admin">Dashboard</a>
                    </li>
                }
                <li class="nav-item">
                    <a class="nav-link" href="/swagger/index.html" target="_blank">API</a>
                </li>
                <li class="nav-item">
                    @if (isAuthenticated)
                    {
                        <a class="nav-link" href="#" @onclick="LogoutAsync">Logout</a>
                    }
                    else
                    {
                        <a class="nav-link" href="/login">Login</a>
                    }
                </li>
            </ul>
        </div>
    </div>
</nav>

<div class="container-fluid">
    <div class="row">
        <main role="main" class="col-md-12">
            @Body
        </main>
    </div>
</div>

<footer class="bg-light text-center py-4 mt-5">
    <div class="container">
        <p class="text-muted">&copy; 2024 Wolf Blockchain. All rights reserved. | v3.0.0</p>
    </div>
</footer>

@code {
    private bool isAuthenticated;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        isAuthenticated = !string.IsNullOrWhiteSpace(await AuthService.GetValidTokenAsync());
        StateHasChanged();
    }

    private async Task LogoutAsync()
    {
        await AuthService.ClearTokenAsync();
        isAuthenticated = false;
        Navigation.NavigateTo("/login", true);
    }
}

<style>
    body {
        background-color: #f5f5f5;
    }

    main {
        min-height: 600px;
        padding-top: 20px;
    }

    footer {
        margin-top: 50px;
        border-top: 1px solid #dee2e6;
    }

    .navbar-brand {
        font-weight: bold;
        font-size: 1.5rem;
    }
</style>
