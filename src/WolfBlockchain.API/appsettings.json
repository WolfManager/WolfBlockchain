{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "ExpirationMinutes": 1440,
    "RefreshTokenExpirationDays": 7
  },
  "Security": {
    "SingleAdminMode": true,
    "OwnerAddress": "WOLFADMIN",
    "MaxFailedAttempts": 5,
    "MaxFailedLoginAttempts": 5,
    "LoginLockoutMinutes": 30,
    "BlockDurationMinutes": 15,
    "SecretRotationIntervalHours": 24,
    "AdminAllowedIps": [
      "127.0.0.1",
      "::1"
    ],
    "AllowedOrigins": [
      "http://localhost:5000",
      "https://localhost:5001"
    ]
  },
  "Cache": {
    "DefaultTtlMinutes": 5,
    "SummaryTtlMinutes": 5,
    "ListTtlMinutes": 10
  },
  "RateLimit": {
    "RequestsPerMinute": 100,
    "BurstSize": 10
  },
  "Monitoring": {
    "EnableMetrics": true,
    "EnableDetailedLogging": false,
    "LogRetentionDays": 7
  },
  "Ollama": {
    "BaseUrl": "http://localhost:11434",
    "Model": "llama3",
    "TimeoutSeconds": 30,
    "SystemPrompt": "You are WolfBot, a helpful AI assistant for the Wolf Blockchain platform. Answer questions about blockchain, smart contracts, tokens, and wallets concisely and accurately."
  }
}
