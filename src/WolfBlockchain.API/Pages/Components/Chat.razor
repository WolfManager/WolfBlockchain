@using System.Net.Http.Json
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Web
@inject HttpClient Http
@inject IJSRuntime JS

<div class="chat-container">
    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white d-flex align-items-center">
            <span class="me-2">🤖</span>
            <h5 class="mb-0">Wolf AI Assistant</h5>
            @if (isLoading)
            {
                <div class="spinner-border spinner-border-sm text-light ms-auto" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            }
        </div>

        <div id="chat-messages" class="card-body chat-messages" @ref="messagesContainer">
            @if (messages.Count == 0)
            {
                <div class="text-center text-muted py-4">
                    <p>👋 Welcome! Ask me anything about WolfBlockchain.</p>
                </div>
            }
            else
            {
                @foreach (var msg in messages)
                {
                    <div class="message-row @(msg.IsUser ? "user-message" : "assistant-message")">
                        <div class="message-bubble @(msg.IsUser ? "bubble-user" : "bubble-assistant")">
                            <div class="message-sender">@(msg.IsUser ? "You" : "Wolf AI")</div>
                            <div class="message-text">@msg.Text</div>
                            <div class="message-time">@msg.Timestamp.ToString("HH:mm")</div>
                        </div>
                    </div>
                }
            }
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-warning mt-2" role="alert">@errorMessage</div>
            }
        </div>

        <div class="card-footer">
            <div class="input-group">
                <input id="chat-input"
                       type="text"
                       class="form-control"
                       placeholder="Type your message…"
                       @bind="inputText"
                       @bind:event="oninput"
                       @onkeydown="OnKeyDown"
                       disabled="@isLoading"
                       autocomplete="off" />
                <button class="btn btn-primary"
                        type="button"
                        @onclick="SendMessage"
                        disabled="@(isLoading || string.IsNullOrWhiteSpace(inputText))">
                    ➤ Send
                </button>
                <button class="btn btn-outline-secondary"
                        type="button"
                        @onclick="ClearChat"
                        title="Clear conversation">
                    🗑
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    private record ChatMessage(string Text, bool IsUser, DateTime Timestamp);

    private readonly List<ChatMessage> messages = new();
    private string inputText = string.Empty;
    private string errorMessage = string.Empty;
    private bool isLoading;
    private ElementReference messagesContainer;

    private async Task SendMessage()
    {
        var text = inputText.Trim();
        if (string.IsNullOrWhiteSpace(text))
            return;

        inputText = string.Empty;
        errorMessage = string.Empty;
        messages.Add(new ChatMessage(text, IsUser: true, DateTime.Now));
        isLoading = true;
        StateHasChanged();
        await ScrollToBottom();

        try
        {
            var payload = new { message = text };
            var response = await Http.PostAsJsonAsync("/api/chat", payload);

            if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadFromJsonAsync<JsonElement>();
                var reply = json.TryGetProperty("reply", out var r) ? r.GetString() ?? string.Empty
                          : json.TryGetProperty("response", out var resp) ? resp.GetString() ?? string.Empty
                          : "(no response)";
                messages.Add(new ChatMessage(reply, IsUser: false, DateTime.Now));
            }
            else
            {
                errorMessage = $"Service unavailable (HTTP {(int)response.StatusCode}). Try again later.";
            }
        }
        catch (HttpRequestException)
        {
            errorMessage = "Could not reach the AI service. Please check your connection.";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
            await ScrollToBottom();
        }
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
            await SendMessage();
    }

    private void ClearChat()
    {
        messages.Clear();
        errorMessage = string.Empty;
        StateHasChanged();
    }

    private async Task ScrollToBottom()
    {
        try
        {
            await JS.InvokeVoidAsync("wolfChat.scrollToBottom", messagesContainer);
        }
        catch (JSException)
        {
            // JS interop may not be available during prerender
        }
    }
}

<style>
    .chat-container {
        max-width: 760px;
        margin: 0 auto;
    }

    .chat-messages {
        min-height: 340px;
        max-height: 480px;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        padding: 1rem;
        background-color: #f8f9fa;
    }

    .message-row {
        display: flex;
    }

    .user-message {
        justify-content: flex-end;
    }

    .assistant-message {
        justify-content: flex-start;
    }

    .message-bubble {
        max-width: 75%;
        padding: 0.5rem 0.8rem;
        border-radius: 12px;
        font-size: 0.92rem;
        word-break: break-word;
    }

    .bubble-user {
        background-color: #0d6efd;
        color: #fff;
        border-bottom-right-radius: 2px;
    }

    .bubble-assistant {
        background-color: #e9ecef;
        color: #212529;
        border-bottom-left-radius: 2px;
    }

    .message-sender {
        font-size: 0.72rem;
        font-weight: 600;
        margin-bottom: 2px;
        opacity: 0.75;
    }

    .message-time {
        font-size: 0.68rem;
        margin-top: 4px;
        opacity: 0.6;
        text-align: right;
    }
</style>
