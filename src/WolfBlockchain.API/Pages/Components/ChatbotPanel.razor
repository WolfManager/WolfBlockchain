@using WolfBlockchain.API.Services
@using Microsoft.AspNetCore.Components.Web

<div class="card shadow-sm h-100">
    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
        <span>🤖 Wolf AI Chatbot <small class="text-muted ms-2">(@modelName)</small></span>
        <div>
            @if (ollamaAvailable)
            {
                <span class="badge bg-success me-2">● Online</span>
            }
            else
            {
                <span class="badge bg-danger me-2">● Offline</span>
            }
            <button class="btn btn-sm btn-outline-light" @onclick="ClearChatAsync">🗑 Clear</button>
        </div>
    </div>

    <div class="card-body d-flex flex-column" style="height: 480px;">
        <!-- Message list -->
        <div class="flex-grow-1 overflow-auto mb-3" id="chatMessages" style="min-height:0;">
            @if (messages.Count == 0)
            {
                <div class="text-muted text-center mt-5">
                    <p>💬 Ask me anything about Wolf Blockchain!</p>
                    <small>I can help with blockchain concepts, smart contracts, transactions, and more.</small>
                </div>
            }
            else
            {
                @foreach (var msg in messages)
                {
                    if (msg.Role == "user")
                    {
                        <div class="d-flex justify-content-end mb-2">
                            <div class="bg-primary text-white rounded p-2 px-3" style="max-width:80%; white-space:pre-wrap;">
                                @msg.Content
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex justify-content-start mb-2">
                            <div class="bg-light border rounded p-2 px-3" style="max-width:80%; white-space:pre-wrap;">
                                @msg.Content
                            </div>
                        </div>
                    }
                }
                @if (isLoading)
                {
                    <div class="d-flex justify-content-start mb-2">
                        <div class="bg-light border rounded p-2 px-3">
                            <span class="spinner-grow spinner-grow-sm text-secondary" role="status"></span>
                            <span class="ms-1 text-muted">Thinking…</span>
                        </div>
                    </div>
                }
            }
        </div>

        <!-- Input area -->
        <div class="input-group">
            <input type="text"
                   class="form-control"
                   placeholder="Type a message…"
                   @bind="inputText"
                   @bind:event="oninput"
                   @onkeydown="HandleKeyDown"
                   disabled="@isLoading" />
            <button class="btn btn-primary" @onclick="SendMessageAsync" disabled="@(isLoading || string.IsNullOrWhiteSpace(inputText))">
                ➤ Send
            </button>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-warning mt-2 mb-0 py-1 px-2 small">⚠️ @errorMessage</div>
        }
    </div>
</div>

@code {
    [Inject] private HttpClient Http { get; set; } = default!;
    [Inject] private IConfiguration Configuration { get; set; } = default!;

    private string sessionId = Guid.NewGuid().ToString("N");
    private string inputText = string.Empty;
    private bool isLoading = false;
    private bool ollamaAvailable = false;
    private string modelName = "llama3";
    private string errorMessage = string.Empty;

    private readonly List<(string Role, string Content)> messages = new();

    protected override async Task OnInitializedAsync()
    {
        await CheckStatusAsync();
    }

    private async Task CheckStatusAsync()
    {
        try
        {
            var response = await Http.GetFromJsonAsync<ChatbotStatusDto>("api/chatbot/status");
            if (response != null)
            {
                ollamaAvailable = response.OllamaAvailable;
                modelName = response.Model ?? "llama3";
            }
        }
        catch
        {
            ollamaAvailable = false;
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
            await SendMessageAsync();
    }

    private async Task SendMessageAsync()
    {
        var text = inputText.Trim();
        if (string.IsNullOrWhiteSpace(text) || isLoading)
            return;

        inputText = string.Empty;
        errorMessage = string.Empty;
        isLoading = true;
        messages.Add(("user", text));

        try
        {
            var payload = new { sessionId, message = text };
            var response = await Http.PostAsJsonAsync("api/chatbot/chat", payload);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ChatResponseDto>();
                if (result != null)
                    messages.Add(("assistant", result.Message ?? string.Empty));
            }
            else if ((int)response.StatusCode == 503)
            {
                errorMessage = "AI service is offline. Please ensure Ollama is running (ollama serve).";
            }
            else if ((int)response.StatusCode == 504)
            {
                errorMessage = "Request timed out. The model may be loading, please try again.";
            }
            else
            {
                errorMessage = $"Error {(int)response.StatusCode}: {response.ReasonPhrase}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Network error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
            await ScrollToBottom();
        }
    }

    private async Task ClearChatAsync()
    {
        messages.Clear();
        errorMessage = string.Empty;
        try
        {
            await Http.DeleteAsync($"api/chatbot/sessions/{sessionId}");
        }
        catch { /* best-effort */ }
        sessionId = Guid.NewGuid().ToString("N");
    }

    private async Task ScrollToBottom()
    {
        // Intentionally no-op in this component to avoid JSInterop dependency.
        // A JS interop call could be added here if auto-scroll is required.
        await Task.CompletedTask;
    }

    // ─── internal DTOs (used only inside this component) ───────────────────────

    private sealed record ChatbotStatusDto
    {
        [System.Text.Json.Serialization.JsonPropertyName("ollamaAvailable")]
        public bool OllamaAvailable { get; init; }
        [System.Text.Json.Serialization.JsonPropertyName("model")]
        public string? Model { get; init; }
    }

    private sealed record ChatResponseDto
    {
        [System.Text.Json.Serialization.JsonPropertyName("message")]
        public string? Message { get; init; }
        [System.Text.Json.Serialization.JsonPropertyName("success")]
        public bool Success { get; init; }
    }
}
