@using System.Collections.Generic
@implements IAsyncDisposable

<div class="tab-pane fade show active">
    <h3>🤖 AI Training Jobs</h3>
    
    <div class="mb-4">
        <button class="btn btn-primary" @onclick="ShowCreateJobModal">➕ New Training Job</button>
        <button class="btn btn-secondary" @onclick="RefreshJobs">🔄 Refresh</button>
    </div>

    @if (isLoading)
    {
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    }
    else if (jobs.Count == 0)
    {
        <div class="alert alert-info">No training jobs found</div>
    }
    else
    {
        <div class="row">
            @foreach (var job in jobs)
            {
                <div class="col-md-6 mb-4">
                    <div class="card">
                        <div class="card-header">
                            <h5>@job.Name</h5>
                            <small class="text-muted">Job ID: @job.JobId</small>
                        </div>
                        <div class="card-body">
                            <p><strong>Model:</strong> @job.ModelType</p>
                            <p><strong>Status:</strong> <span class="badge @GetStatusBadgeClass(job.Status)">@job.Status</span></p>
                            <p><strong>Progress:</strong> @job.Progress%</p>
                            <div class="progress mb-3">
                                <div class="progress-bar @GetProgressBarClass(job.Status)" role="progressbar" style="width: @job.Progress%;" aria-valuenow="@job.Progress" aria-valuemin="0" aria-valuemax="100">@job.Progress%</div>
                            </div>
                            <p><strong>Started:</strong> @job.StartedAt.ToString("yyyy-MM-dd HH:mm:ss")</p>
                            <p><strong>ETA:</strong> @(job.EstimatedCompletion?.ToString("yyyy-MM-dd HH:mm:ss") ?? "Calculating...")</p>
                            <p><strong>Accuracy:</strong> @job.Accuracy.ToString("F2")%</p>
                            @if (!string.IsNullOrEmpty(job.Results))
                            {
                                <p><strong>Results:</strong> <small>@job.Results</small></p>
                            }
                        </div>
                        <div class="card-footer">
                            @if (job.Status == "Running")
                            {
                                <button class="btn btn-sm btn-warning" @onclick="() => PauseJob(job.JobId)">⏸️ Pause</button>
                                <button class="btn btn-sm btn-danger" @onclick="() => CancelJob(job.JobId)">⏹️ Cancel</button>
                            }
                            else if (job.Status == "Paused")
                            {
                                <button class="btn btn-sm btn-success" @onclick="() => ResumeJob(job.JobId)">▶️ Resume</button>
                            }
                            <button class="btn btn-sm btn-info" @onclick="() => ShowJobDetails(job)">Details</button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <!-- Create Job Modal -->
    @if (showCreateJobModal)
    {
        <div class="modal d-block" style="background-color: rgba(0,0,0,0.5);">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Create New Training Job</h5>
                        <button type="button" class="btn-close" @onclick="CloseCreateJobModal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Job Name</label>
                            <input type="text" class="form-control" placeholder="e.g., Token Price Predictor" @bind="newJob.Name">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Model Type</label>
                            <select class="form-select" @bind="newJob.ModelType">
                                <option value="neural-network">Neural Network</option>
                                <option value="transformer">Transformer</option>
                                <option value="random-forest">Random Forest</option>
                                <option value="lstm">LSTM</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Dataset URL</label>
                            <input type="url" class="form-control" placeholder="https://..." @bind="newJob.DatasetUrl">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Training Parameters (JSON)</label>
                            <textarea class="form-control" rows="5" placeholder='{"epochs": 100, "batch_size": 32, "learning_rate": 0.001}' @bind="newJob.Parameters"></textarea>
                        </div>
                        <div class="alert alert-info">
                            📊 Training will run on GPU cluster if available.
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CloseCreateJobModal">Cancel</button>
                        <button type="button" class="btn btn-primary" @onclick="CreateJob">Start Training</button>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Job Details -->
    @if (selectedJob != null && !showCreateJobModal)
    {
        <div class="card mt-4">
            <div class="card-header bg-light">
                <h5>Job Details: @selectedJob.Name</h5>
                <button class="btn btn-sm btn-secondary float-end" @onclick="ClearSelection">Close</button>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <p><strong>Job ID:</strong> @selectedJob.JobId</p>
                        <p><strong>Status:</strong> <span class="badge @GetStatusBadgeClass(selectedJob.Status)">@selectedJob.Status</span></p>
                        <p><strong>Model Type:</strong> @selectedJob.ModelType</p>
                        <p><strong>Progress:</strong> @selectedJob.Progress%</p>
                    </div>
                    <div class="col-md-6">
                        <p><strong>Started:</strong> @selectedJob.StartedAt</p>
                        <p><strong>ETA:</strong> @(selectedJob.EstimatedCompletion?.ToString("yyyy-MM-dd HH:mm:ss") ?? "N/A")</p>
                        <p><strong>Accuracy:</strong> @selectedJob.Accuracy.ToString("F2")%</p>
                        <p><strong>Loss:</strong> @selectedJob.Loss.ToString("F4")</p>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(selectedJob.Results))
                {
                    <div class="mt-3">
                        <h6>Results</h6>
                        <pre>@selectedJob.Results</pre>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private List<TrainingJobData> jobs = new();
    private bool isLoading;
    private bool showCreateJobModal;
    private TrainingJobData? selectedJob;
    private CreateJobModel newJob = new();

    protected override async Task OnInitializedAsync()
    {
        await RefreshJobs();
    }

    private async Task RefreshJobs()
    {
        isLoading = true;
        try
        {
            // Placeholder data
            jobs = new List<TrainingJobData>
            {
                new TrainingJobData 
                { 
                    JobId = "JOB001", 
                    Name = "Token Price Predictor", 
                    ModelType = "LSTM", 
                    Status = "Running", 
                    Progress = 65,
                    StartedAt = DateTime.UtcNow.AddHours(-4),
                    EstimatedCompletion = DateTime.UtcNow.AddHours(2),
                    Accuracy = 87.5m,
                    Loss = 0.1234m,
                    Results = ""
                },
                new TrainingJobData 
                { 
                    JobId = "JOB002", 
                    Name = "Fraud Detection Model", 
                    ModelType = "Neural Network", 
                    Status = "Completed", 
                    Progress = 100,
                    StartedAt = DateTime.UtcNow.AddDays(-2),
                    EstimatedCompletion = DateTime.UtcNow.AddDays(-2).AddHours(6),
                    Accuracy = 92.3m,
                    Loss = 0.0856m,
                    Results = "Model converged successfully. F1-score: 0.918"
                },
            };
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ShowCreateJobModal() => showCreateJobModal = true;
    private void CloseCreateJobModal() { showCreateJobModal = false; newJob = new(); }

    private async Task CreateJob()
    {
        if (string.IsNullOrWhiteSpace(newJob.Name))
            return;

        jobs.Add(new TrainingJobData
        {
            JobId = $"JOB{Guid.NewGuid().ToString()[..3].ToUpper()}",
            Name = newJob.Name,
            ModelType = newJob.ModelType,
            Status = "Queued",
            Progress = 0,
            StartedAt = DateTime.UtcNow,
            EstimatedCompletion = DateTime.UtcNow.AddHours(8),
            Accuracy = 0,
            Loss = 0,
            Results = ""
        });

        CloseCreateJobModal();
    }

    private async Task PauseJob(string jobId)
    {
        var job = jobs.FirstOrDefault(j => j.JobId == jobId);
        if (job != null) job.Status = "Paused";
    }

    private async Task ResumeJob(string jobId)
    {
        var job = jobs.FirstOrDefault(j => j.JobId == jobId);
        if (job != null) job.Status = "Running";
    }

    private async Task CancelJob(string jobId)
    {
        var job = jobs.FirstOrDefault(j => j.JobId == jobId);
        if (job != null) job.Status = "Cancelled";
    }

    private void ShowJobDetails(TrainingJobData job) => selectedJob = job;
    private void ClearSelection() => selectedJob = null;

    private string GetStatusBadgeClass(string status) => status switch
    {
        "Running" => "bg-success",
        "Paused" => "bg-warning",
        "Completed" => "bg-info",
        "Cancelled" => "bg-danger",
        _ => "bg-secondary"
    };

    private string GetProgressBarClass(string status) => status switch
    {
        "Running" => "progress-bar-striped progress-bar-animated",
        "Completed" => "bg-success",
        "Cancelled" => "bg-danger",
        _ => ""
    };

    public class TrainingJobData
    {
        public string JobId { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string ModelType { get; set; } = string.Empty;
        public string Status { get; set; } = "Queued";
        public int Progress { get; set; }
        public DateTime StartedAt { get; set; }
        public DateTime? EstimatedCompletion { get; set; }
        public decimal Accuracy { get; set; }
        public decimal Loss { get; set; }
        public string Results { get; set; } = string.Empty;
    }

    public class CreateJobModel
    {
        public string Name { get; set; } = string.Empty;
        public string ModelType { get; set; } = "neural-network";
        public string DatasetUrl { get; set; } = string.Empty;
        public string Parameters { get; set; } = string.Empty;
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        await Task.CompletedTask;
    }
}
