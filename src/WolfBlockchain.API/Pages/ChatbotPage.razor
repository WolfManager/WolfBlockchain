@page "/chatbot"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Web
@using System.Net.Http.Headers
@using System.Text.Json
@attribute [Authorize]
@inject HttpClient Http
@inject ClientAuthService AuthService
@inject NavigationManager Navigation

<div class="container-fluid mt-4">
    <h1 class="mb-3">🤖 WolfBot – AI Assistant</h1>
    <p class="text-muted mb-4">Ask WolfBot anything about blockchain, tokens, or smart contracts.</p>

    <!-- Status Badge -->
    <div class="mb-3">
        <span class="badge @(backendAvailable ? "bg-success" : "bg-warning text-dark")">
            @(backendAvailable ? $"✅ {backendName} online" : $"⚠️ {backendName} (limited mode)")
        </span>
        <span class="ms-2 text-muted small">Session: @(sessionId ?? "none")</span>
    </div>

    <!-- Chat Window -->
    <div class="card shadow-sm mb-3" style="height: 460px; overflow-y: auto;" id="chat-window">
        <div class="card-body p-3">
            @if (messages.Count == 0)
            {
                <p class="text-muted fst-italic">Start a conversation by typing a message below.</p>
            }
            else
            {
                @foreach (var msg in messages)
                {
                    <div class="d-flex @(msg.Role == "user" ? "justify-content-end" : "justify-content-start") mb-2">
                        <div class="p-2 rounded @(msg.Role == "user" ? "bg-primary text-white" : "bg-light text-dark")"
                             style="max-width: 75%; white-space: pre-wrap; word-break: break-word;">
                            <small class="fw-bold">@(msg.Role == "user" ? "You" : "🐺 WolfBot")</small>
                            <br />
                            @msg.Content
                        </div>
                    </div>
                }
            }
            @if (isLoading)
            {
                <div class="d-flex justify-content-start mb-2">
                    <div class="p-2 rounded bg-light text-muted">
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                        WolfBot is thinking…
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Input Area -->
    <div class="input-group mb-2">
        <input type="text"
               class="form-control"
               placeholder="Type your message…"
               @bind="userInput"
               @bind:event="oninput"
               @onkeydown="OnKeyDown"
               disabled="@isLoading" />
        <button class="btn btn-primary" @onclick="SendMessage" disabled="@(isLoading || string.IsNullOrWhiteSpace(userInput))">
            @(isLoading ? "Sending…" : "Send")
        </button>
        <button class="btn btn-outline-secondary" @onclick="ClearSession" disabled="@isLoading" title="Clear conversation">
            🗑️
        </button>
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-warning mt-2">⚠️ @errorMessage</div>
    }
</div>

@code {
    private List<UiMessage> messages = new();
    private string userInput = string.Empty;
    private string? sessionId;
    private bool isLoading;
    private bool backendAvailable;
    private string backendName = "AI";
    private string? errorMessage;

    private record UiMessage(string Role, string Content);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        var token = await AuthService.GetValidTokenAsync();
        if (string.IsNullOrWhiteSpace(token))
        {
            Navigation.NavigateTo("/login", true);
            return;
        }

        Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
        await LoadStatusAsync();
        StateHasChanged();
    }

    private async Task LoadStatusAsync()
    {
        try
        {
            var response = await Http.GetAsync("api/chatbot/status");
            if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadAsStringAsync();
                using var doc = JsonDocument.Parse(json);
                backendAvailable = doc.RootElement.TryGetProperty("ollamaAvailable", out var avail) && avail.GetBoolean();
                backendName = doc.RootElement.TryGetProperty("backend", out var bn) ? bn.GetString() ?? "AI" : "AI";
            }
        }
        catch
        {
            backendAvailable = false;
        }
    }

    private async Task SendMessage()
    {
        var text = userInput.Trim();
        if (string.IsNullOrWhiteSpace(text)) return;

        messages.Add(new UiMessage("user", text));
        userInput = string.Empty;
        isLoading = true;
        errorMessage = null;
        StateHasChanged();

        try
        {
            var payload = new { message = text, sessionId };
            var response = await Http.PostAsJsonAsync("api/chatbot/chat", payload);
            var json = await response.Content.ReadAsStringAsync();

            if (response.IsSuccessStatusCode)
            {
                using var doc = JsonDocument.Parse(json);
                var reply = doc.RootElement.TryGetProperty("reply", out var r) ? r.GetString() ?? string.Empty : string.Empty;
                sessionId = doc.RootElement.TryGetProperty("sessionId", out var s) ? s.GetString() : sessionId;
                messages.Add(new UiMessage("assistant", reply));
            }
            else
            {
                using var doc = JsonDocument.Parse(json);
                var err = doc.RootElement.TryGetProperty("error", out var e) ? e.GetString() : "Unknown error";
                errorMessage = err ?? "An error occurred.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to send message: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task ClearSession()
    {
        if (!string.IsNullOrWhiteSpace(sessionId))
        {
            try { await Http.DeleteAsync($"api/chatbot/sessions/{sessionId}"); } catch { /* best effort */ }
        }

        messages.Clear();
        sessionId = null;
        errorMessage = null;
        StateHasChanged();
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey && !isLoading && !string.IsNullOrWhiteSpace(userInput))
            await SendMessage();
    }
}

<style>
    #chat-window {
        border: 1px solid #dee2e6;
        border-radius: 8px;
        scroll-behavior: smooth;
    }

    .input-group .form-control:focus {
        box-shadow: none;
        border-color: #0d6efd;
    }
</style>
