@using System.Collections.Generic

<div class="tab-pane fade show active">
    <h3>👥 User Management</h3>
    
    <div class="mt-4">
        <button class="btn btn-primary mb-3">➕ Add User</button>
        <input type="text" class="form-control mb-3" placeholder="Search users...">
        
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>User ID</th>
                        <th>Username</th>
                        <th>Address</th>
                        <th>Role</th>
                        <th>Balance</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>USR001</td>
                        <td>alex_crypto</td>
                        <td><code>WOLF8a2c4...</code></td>
                        <td><span class="badge bg-info">Validator</span></td>
                        <td>50,000 WOLF</td>
                        <td><span class="badge bg-success">Active</span></td>
                        <td>2024-01-15</td>
                        <td>
                            <button class="btn btn-sm btn-info">Edit</button>
                            <button class="btn btn-sm btn-danger">Deactivate</button>
                        </td>
                    </tr>
                    <tr>
                        <td>USR002</td>
                        <td>sam_ai</td>
                        <td><code>WOLFb9d3e...</code></td>
                        <td><span class="badge bg-secondary">User</span></td>
                        <td>25,500 WOLF</td>
                        <td><span class="badge bg-success">Active</span></td>
                        <td>2024-01-20</td>
                        <td>
                            <button class="btn btn-sm btn-info">Edit</button>
                            <button class="btn btn-sm btn-danger">Deactivate</button>
                        </td>
                    </tr>
                    <tr>
                        <td>USR003</td>
                        <td>dev_wolf</td>
                        <td><code>WOLFc1f5a...</code></td>
                        <td><span class="badge bg-warning">Admin</span></td>
                        <td>1,000,000 WOLF</td>
                        <td><span class="badge bg-success">Active</span></td>
                        <td>2024-01-10</td>
                        <td>
                            <button class="btn btn-sm btn-info">Edit</button>
                            <button class="btn btn-sm btn-danger">Deactivate</button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- User Details Modal -->
    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-light">
                    <h5>User Roles Overview</h5>
                </div>
                <div class="card-body">
                    <ul class="list-group">
                        <li class="list-group-item d-flex justify-content-between">
                            <span>Admins:</span>
                            <strong>3</strong>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            <span>Validators:</span>
                            <strong>12</strong>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            <span>Regular Users:</span>
                            <strong>135</strong>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

