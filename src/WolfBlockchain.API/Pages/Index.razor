@page "/"

<PageTitle>Wolf Blockchain Admin</PageTitle>

<div class="container-fluid mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="text-center mb-4">
                <h1>🐺 Wolf Blockchain</h1>
                <p class="lead">AI-Powered Blockchain Platform</p>
            </div>

            <div class="row mb-4">
                <div class="col-md-4">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">Admin Dashboard</h5>
                            <p class="card-text">Dashboard access is restricted and requires authenticated owner credentials.</p>
                            <a href="/login" class="btn btn-primary">🔐 Owner Login</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">API Documentation</h5>
                            <p class="card-text">View Swagger API documentation for integration.</p>
                            <a href="/swagger/index.html" class="btn btn-info">📚 View API Docs</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">🤖 AI Chatbot</h5>
                            <p class="card-text">Chat with WolfBot, the AI assistant powered by Ollama.</p>
                            <a href="/chatbot" class="btn btn-success">💬 Open Chat</a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header bg-light">
                    <h5>Quick Stats</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3">
                            <div class="text-center">
                                <h3 class="text-primary">1,234</h3>
                                <p class="text-muted">Total Blocks</p>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="text-center">
                                <h3 class="text-success">150</h3>
                                <p class="text-muted">Active Users</p>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="text-center">
                                <h3 class="text-info">8</h3>
                                <p class="text-muted">Token Types</p>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="text-center">
                                <h3 class="text-warning">42</h3>
                                <p class="text-muted">AI Jobs</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
