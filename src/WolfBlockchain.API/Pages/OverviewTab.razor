@using System.Collections.Generic
@using WolfBlockchain.API.Pages.Components

<div class="tab-pane fade show active">
    <h3>📊 Dashboard Overview</h3>
    
    <!-- Real-time Connection Status -->
    <RealtimeDashboard />
    
    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-light">
                    <h5>Network Statistics</h5>
                </div>
                <div class="card-body">
                    <ul class="list-group">
                        <li class="list-group-item d-flex justify-content-between">
                            <span>Total Blocks:</span>
                            <strong>1,234</strong>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            <span>Total Transactions:</span>
                            <strong>45,678</strong>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            <span>Active Nodes:</span>
                            <strong>12</strong>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            <span>Network Hash Rate:</span>
                            <strong>2.5 PH/s</strong>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            <span>Difficulty:</span>
                            <strong>4,000,000</strong>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-light">
                    <h5>Wolf Coin Statistics</h5>
                </div>
                <div class="card-body">
                    <ul class="list-group">
                        <li class="list-group-item d-flex justify-content-between">
                            <span>Total Supply:</span>
                            <strong>1,000,000,000</strong>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            <span>Circulating Supply:</span>
                            <strong>450,000,000</strong>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            <span>Total Staked:</span>
                            <strong>120,000,000</strong>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            <span>Current Price:</span>
                            <strong>$0.42</strong>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            <span>Market Cap:</span>
                            <strong>$189,000,000</strong>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header bg-light">
                    <h5>Recent Activity</h5>
                </div>
                <div class="card-body">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Time</th>
                                <th>Event</th>
                                <th>Address</th>
                                <th>Value</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>2 mins ago</td>
                                <td>Transaction</td>
                                <td>WOLF8a2c4...</td>
                                <td>1,500 WOLF</td>
                                <td><span class="badge bg-success">Confirmed</span></td>
                            </tr>
                            <tr>
                                <td>5 mins ago</td>
                                <td>Token Transfer</td>
                                <td>WOLFb9d3e...</td>
                                <td>500 AI</td>
                                <td><span class="badge bg-success">Confirmed</span></td>
                            </tr>
                            <tr>
                                <td>8 mins ago</td>
                                <td>Staking</td>
                                <td>WOLFc1f5a...</td>
                                <td>10,000 WOLF</td>
                                <td><span class="badge bg-success">Confirmed</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

