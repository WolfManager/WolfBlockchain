@using System.Collections.Generic

<div class="tab-pane fade show active">
    <h3>⛓️ Blockchain Explorer</h3>
    
    <div class="mt-4">
        <div class="input-group mb-3">
            <input type="text" class="form-control" placeholder="Search block, transaction, or address...">
            <button class="btn btn-primary" type="button">Search</button>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card">
                <div class="card-body text-center">
                    <h5>Latest Block</h5>
                    <h2 class="text-primary">#1,234</h2>
                    <small class="text-muted">2 mins ago</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card">
                <div class="card-body text-center">
                    <h5>Transactions/Block</h5>
                    <h2 class="text-success">127</h2>
                    <small class="text-muted">Avg last 10 blocks</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card">
                <div class="card-body text-center">
                    <h5>Block Time</h5>
                    <h2 class="text-info">15s</h2>
                    <small class="text-muted">Average</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card">
                <div class="card-body text-center">
                    <h5>Network Hash</h5>
                    <h2 class="text-warning">2.5 PH/s</h2>
                    <small class="text-muted">Current</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Blocks -->
    <div class="card mb-4">
        <div class="card-header bg-light">
            <h5>📦 Recent Blocks</h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-sm table-hover">
                    <thead>
                        <tr>
                            <th>Block #</th>
                            <th>Hash</th>
                            <th>Miner</th>
                            <th>Transactions</th>
                            <th>Difficulty</th>
                            <th>Time</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><strong>1,234</strong></td>
                            <td><code>0x8A2C4...</code></td>
                            <td>alex_crypto</td>
                            <td>128</td>
                            <td>4,000,000</td>
                            <td>2 mins</td>
                        </tr>
                        <tr>
                            <td><strong>1,233</strong></td>
                            <td><code>0xB9D3E...</code></td>
                            <td>sam_ai</td>
                            <td>115</td>
                            <td>3,999,850</td>
                            <td>4 mins</td>
                        </tr>
                        <tr>
                            <td><strong>1,232</strong></td>
                            <td><code>0xC1F5A...</code></td>
                            <td>validator01</td>
                            <td>142</td>
                            <td>3,999,700</td>
                            <td>6 mins</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Recent Transactions -->
    <div class="card">
        <div class="card-header bg-light">
            <h5>💱 Recent Transactions</h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-sm table-hover">
                    <thead>
                        <tr>
                            <th>TX Hash</th>
                            <th>From</th>
                            <th>To</th>
                            <th>Amount</th>
                            <th>Fee</th>
                            <th>Status</th>
                            <th>Block</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><code>0xTX001...</code></td>
                            <td>WOLF8A2C4...</td>
                            <td>WOLFB9D3E...</td>
                            <td>1,500 WOLF</td>
                            <td>1.5 WOLF</td>
                            <td><span class="badge bg-success">Confirmed</span></td>
                            <td>1,234</td>
                        </tr>
                        <tr>
                            <td><code>0xTX002...</code></td>
                            <td>WOLFB9D3E...</td>
                            <td>WOLFC1F5A...</td>
                            <td>500 AI</td>
                            <td>0.5 AI</td>
                            <td><span class="badge bg-success">Confirmed</span></td>
                            <td>1,233</td>
                        </tr>
                        <tr>
                            <td><code>0xTX003...</code></td>
                            <td>WOLFC1F5A...</td>
                            <td>WOLF8A2C4...</td>
                            <td>10,000 WOLF</td>
                            <td>10 WOLF</td>
                            <td><span class="badge bg-success">Confirmed</span></td>
                            <td>1,232</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
}
